# Database Configuration
DATABASE_URL=sqlite+aiosqlite:///./paybot.db

# Payment Service Configuration
# Required in production
XENDIT_SECRET_KEY=your_xendit_secret_key

# Telegram Bot Configuration
# Required in production
TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# Supabase Configuration
SUPABASE_URL=your_supabase_project_url
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_KEY=your_supabase_service_key

# Application Configuration
ENVIRONMENT=dev
DEBUG=false
PORT=8000

# Backend URL (for webhooks)
# Required for the Telegram webhook to be auto-registered on startup.
# Set this to your Railway backend public URL, e.g. https://paybot-backend.up.railway.app
PYTHON_BACKEND_URL=https://your-backend-url.railway.app

# CORS Configuration
ALLOWED_ORIGINS=https://your-frontend-url.railway.app,http://localhost:3000
