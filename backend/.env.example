# Database Configuration
DATABASE_URL=sqlite+aiosqlite:///./paybot.db

# Payment Service Configuration
# Required in production
XENDIT_SECRET_KEY=your_xendit_secret_key

# Telegram Bot Configuration
# Required in production
TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# Application Configuration
ENVIRONMENT=dev
DEBUG=false
PORT=8000

# Backend URL (for webhooks and Telegram webhook auto-registration)
PYTHON_BACKEND_URL=https://your-backend-url.railway.app

# CORS Configuration
ALLOWED_ORIGINS=https://your-frontend-url.railway.app,http://localhost:3000

# JWT Authentication (REQUIRED for admin dashboard login)
# Generate a secure random key, e.g.: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=your_secure_random_secret_key_here
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# Admin Login Configuration (REQUIRED for dashboard access)
# The Telegram user ID(s) allowed to log in as admin (comma-separated)
TELEGRAM_ADMIN_IDS=your_telegram_user_id
