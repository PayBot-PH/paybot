# Database Configuration
DATABASE_URL=sqlite+aiosqlite:///./paybot.db

# Payment Service Configuration
# Required in production
XENDIT_SECRET_KEY=your_xendit_secret_key

# Maya Business Manager API - for WeChat Pay QR codes
# Get keys from Maya Business Manager portal: https://portal.maya.ph
MAYA_PUBLIC_KEY=pk-your-maya-public-key
MAYA_SECRET_KEY=sk-your-maya-secret-key

# Security Bank Collect (Magpie) API - for Alipay & WeChat QR payments
SBC_MERCHANT_ID=your_sbc_merchant_id
SBC_PUBLIC_KEY=your_sbc_public_key
SBC_SECRET_KEY=your_sbc_secret_key

# Telegram Bot Configuration
# Required in production
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
# Optional explicit bot username for Telegram Login Widget runtime config (without @)
TELEGRAM_BOT_USERNAME=your_telegram_bot_username

# Application Configuration
ENVIRONMENT=dev
DEBUG=false
PORT=8000

# Backend URL (for webhooks, Telegram webhook auto-registration, and static QR image URLs)
# The USDT TRC20 QR image is served at {PYTHON_BACKEND_URL}/images/usdt_trc20_qr.png
PYTHON_BACKEND_URL=https://your-backend-url.railway.app

# CORS Configuration
ALLOWED_ORIGINS=https://your-frontend-url.railway.app,http://localhost:3000

# JWT Authentication (REQUIRED for admin dashboard login)
# Generate a secure random key, e.g.: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=your_secure_random_secret_key_here
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# Admin Login Configuration (REQUIRED for dashboard access)
# Comma-separated list of Telegram user IDs or @usernames allowed to log in as admin.
# Numeric IDs (e.g. 123456789) or Telegram usernames prefixed with @ (e.g. @traxionpay).
TELEGRAM_ADMIN_IDS=@traxionpay,8595884149

# GitHub Webhook Integration (OPTIONAL — enables real-time PR updates in the dashboard)
# Generate a random secret and set the same value in your GitHub repository webhook settings.
# e.g.: python -c "import secrets; print(secrets.token_hex(32))"
GITHUB_WEBHOOK_SECRET=your_github_webhook_secret_here
