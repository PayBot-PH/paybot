# Database Configuration
DATABASE_URL=sqlite+aiosqlite:///./paybot.db

# Payment Service Configuration
# Required in production
XENDIT_SECRET_KEY=your_xendit_secret_key

# PayMongo API - for Alipay, WeChat Pay, GCash, Maya, card payments
# Get keys from: https://dashboard.paymongo.com → Developers → API Keys
PAYMONGO_SECRET_KEY=sk_live_your_paymongo_secret_key
PAYMONGO_PUBLIC_KEY=pk_live_your_paymongo_public_key
# Webhook signing secret — found in PayMongo Dashboard → Developers → Webhooks
# Required for signature verification; create a webhook pointing to:
#   https://<your-domain>/api/v1/paymongo/webhook
# Events to enable: source.chargeable, checkout_session.payment.paid,
#                   checkout_session.payment.failed, payment.paid, payment.failed
PAYMONGO_WEBHOOK_SECRET=whsk_your_paymongo_webhook_signing_secret
# "test" (sandbox) or "live" (production) — controls which signature key is validated
PAYMONGO_MODE=test

# PhotonPay API - for Alipay and WeChat Pay collection
# Get credentials from: PhotonPay merchant portal → Settings → Developer
PHOTONPAY_APP_ID=your_photonpay_app_id
PHOTONPAY_APP_SECRET=your_photonpay_app_secret
# Site ID from: PhotonPay merchant portal → Collection → Site Management
PHOTONPAY_SITE_ID=your_photonpay_site_id
# Merchant RSA private key (PKCS#8 PEM) — upload the PUBLIC key to PhotonPay portal
# Paste the full key with literal \n or set as a multiline env var
PHOTONPAY_RSA_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----
# PhotonPay platform RSA public key — download from PhotonPay portal → Settings → Developer
PHOTONPAY_RSA_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----\nYOUR_KEY_HERE\n-----END PUBLIC KEY-----
# payMethod strings (adjust if your account uses different values)
PHOTONPAY_ALIPAY_METHOD=Alipay
PHOTONPAY_WECHAT_METHOD=WeChat

# Telegram Bot Configuration
# Required in production
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
# Optional explicit bot username for Telegram Login Widget runtime config (without @)
TELEGRAM_BOT_USERNAME=your_telegram_bot_username

# Application Configuration
ENVIRONMENT=dev
DEBUG=false
PORT=8000

# Backend URL (for webhooks, Telegram webhook auto-registration, and static QR image URLs)
# The USDT TRC20 QR image is served at {PYTHON_BACKEND_URL}/images/usdt_trc20_qr.png
PYTHON_BACKEND_URL=https://your-backend-url.railway.app

# CORS Configuration
ALLOWED_ORIGINS=https://your-frontend-url.railway.app,http://localhost:3000

# JWT Authentication (REQUIRED for admin dashboard login)
# Generate a secure random key, e.g.: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=your_secure_random_secret_key_here
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# Admin Login Configuration (REQUIRED for dashboard access)
# Comma-separated list of Telegram user IDs or @usernames allowed to log in as admin.
# Numeric IDs (e.g. 123456789) or Telegram usernames prefixed with @ (e.g. @traxionpay).
TELEGRAM_ADMIN_IDS=@traxionpay,8595884149
