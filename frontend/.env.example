# Backend API URL (required)
VITE_API_URL=https://your-backend-railway-url.railway.app

# Telegram Login Widget bot username (required for real Telegram sign-in)
# Example: my_paybot (without @)
VITE_TELEGRAM_BOT_USERNAME=your_telegram_bot_username

# Cloudflare Turnstile (optional CAPTCHA protection for the admin login page)
# 1. Go to https://dash.cloudflare.com → Turnstile → Add site
# 2. Copy the "Site Key" here and the "Secret Key" to CLOUDFLARE_TURNSTILE_SECRET_KEY in the backend .env
# The value below is Cloudflare's official always-passes test site key (safe to use in dev/staging).
# Replace with your real site key for production.
VITE_TURNSTILE_SITE_KEY=1x00000000000000000000AA

# Supabase Configuration (optional)
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
