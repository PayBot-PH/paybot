# Backend API Configuration
VITE_API_URL=https://your-backend-railway-url.railway.app

# Supabase Configuration
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# ==== Runtime ====
APP_ENV=production
FLASK_ENV=production
FLASK_DEBUG=0

# ==== Telegram Bot ====
BOT_TOKEN=your-telegram-bot-token-here

# Comma-separated list of Telegram user IDs allowed in the admin panel
ADMIN_IDS=123456789,987654321

# ==== Admin UI / Security ====
# Use a long, random value in real envs
SECRET_KEY=change-this-in-production
# Session expiry in seconds (e.g. 3600 = 1 hour)
ADMIN_SESSION_EXPIRY=3600

# ==== Database ====
# Example for PostgreSQL; change to match your production DB
DATABASE_URL=postgresql+psycopg2://user:password@host:5432/paybot

# ==== Webhook / Server (if applicable) ====
# Public HTTPS URL that Telegram will call for webhooks (if you use them)
TELEGRAM_WEBHOOK_URL=https://your-domain.com/webhook
# Bind options for Flask / app server
APP_HOST=0.0.0.0
APP_PORT=5000
